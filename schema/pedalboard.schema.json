{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Setlist",
  "type": "object",
  "required": [
    "presets"
  ],
  "properties": {
    "presets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PresetConfig"
      }
    }
  },
  "definitions": {
    "ActionYaml": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "delay"
          ],
          "properties": {
            "delay": {
              "type": "integer",
              "format": "uint16",
              "minimum": 0.0
            }
          }
        },
        {
          "type": "object",
          "required": [
            "cc"
          ],
          "properties": {
            "cc": {
              "type": "integer",
              "format": "uint8",
              "minimum": 0.0
            },
            "channel": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint8",
              "minimum": 0.0
            },
            "value": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint8",
              "minimum": 0.0
            }
          }
        },
        {
          "type": "object",
          "required": [
            "program_change"
          ],
          "properties": {
            "channel": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint8",
              "minimum": 0.0
            },
            "program_change": {
              "type": "integer",
              "format": "uint8",
              "minimum": 0.0
            }
          }
        },
        {
          "type": "object",
          "required": [
            "note"
          ],
          "properties": {
            "channel": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint8",
              "minimum": 0.0
            },
            "note": {
              "type": "integer",
              "format": "uint8",
              "minimum": 0.0
            }
          }
        }
      ]
    },
    "AnalogYamlConfig": {
      "type": "object",
      "required": [
        "cc",
        "label"
      ],
      "properties": {
        "cc": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "channel": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "label": {
          "type": "string"
        },
        "max": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "min": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        }
      }
    },
    "ButtonConfig": {
      "type": "object",
      "required": [
        "label"
      ],
      "properties": {
        "actions": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/ActionYaml"
          }
        },
        "animation": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "cc": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "channel": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "color": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "label": {
          "type": "string"
        },
        "level": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "note": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "on_long_press": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "program_change": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "radio_group": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "renderer": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "renderer_param": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "reverse": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "toggle": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "value": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "values": {
          "default": null,
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          }
        }
      }
    },
    "DefaultsConfig": {
      "description": "Default initial state for a preset on first activation.",
      "type": "object",
      "properties": {
        "buttons": {
          "description": "Button keys (A-F) mapped to \"on\" or \"off\". Omitted = off.",
          "default": {},
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "encoders": {
          "description": "Encoder keys (Vol, Gain) mapped to initial value (0-127). Omitted = 0.",
          "default": {},
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          }
        }
      }
    },
    "EncoderConfig": {
      "type": "object",
      "required": [
        "label"
      ],
      "properties": {
        "cc": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "minimum": 0.0
        },
        "channel": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "label": {
          "type": "string"
        }
      }
    },
    "PresetConfig": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "analog": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/AnalogYamlConfig"
          }
        },
        "buttons": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/ButtonConfig"
          }
        },
        "defaults": {
          "description": "Initial state: which buttons start active and encoder starting values.",
          "anyOf": [
            {
              "$ref": "#/definitions/DefaultsConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "encoders": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/EncoderConfig"
          }
        },
        "name": {
          "type": "string"
        }
      }
    }
  }
}
